#!/usr/bin/env python3
"""communicate — run multiple AI agents toward one goal via a shared ledger.

The runner does deliberately little: it schedules turns and hands each agent
its identity, role, the goal, and the ledger path. The agents do real work in
the working directory and coordinate by appending entries to the ledger, per
the communicate.md protocol (SPEC.md). The ledger — not this process — is the
source of truth, so a crashed run resumes by simply running again.

Usage:
    communicate demo              watch two built-in agents collaborate
                                  (no API keys, finishes in seconds)
    communicate init              guided setup: goal + agents -> crew.toml
    communicate run               run agents until GOAL-COMPLETE is APPROVED
    communicate run --rounds 5    override max rounds
    communicate status            show goal, agents, and the ledger tail

  You are the crew's conscience — watch them, guide them, stop them:
    communicate watch             live view of ledger entries as they land
    communicate say <message>     add an Owner note; agents treat the newest
                                  Owner entry as their top-priority instruction
    communicate stop [reason]     tell a running crew to halt after the
                                  current turn

Requires Python 3.11+ (stdlib only).
"""

from __future__ import annotations

import argparse
import datetime
import re
import shlex
import shutil
import subprocess
import sys
import time
import tomllib
from pathlib import Path

