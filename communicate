def main() -> None:
    parser = argparse.ArgumentParser(prog="communicate", description=__doc__)
    sub = parser.add_subparsers(dest="cmd", required=False)

    p_demo = sub.add_parser("demo", help="watch two built-in agents collaborate (no API keys)")
    p_demo.set_defaults(fn=cmd_demo)

    p_init = sub.add_parser("init", help="guided setup: goal + agents -> crew.toml")
    p_init.add_argument("--force", action="store_true", help="overwrite existing crew.toml")
    p_init.add_argument("--defaults", action="store_true", help="skip the wizard, write the template")
    p_init.set_defaults(fn=cmd_init)

    p_run = sub.add_parser("run", help="run agents toward the goal")
    p_run.add_argument("--rounds", type=int, default=None)
    p_run.set_defaults(fn=cmd_run)

    p_doctor = sub.add_parser("doctor", help="preflight: is every agent invocable?")
    p_doctor.add_argument("--live", action="store_true",
                          help="also do a real round-trip per agent (costs a few tokens)")
    p_doctor.add_argument("--timeout", type=int, default=120,
                          help="seconds per live round-trip (default 120)")
    p_doctor.set_defaults(fn=cmd_doctor)

    p_cmds = sub.add_parser("commands", help="one-screen cheat sheet of every command")
    p_cmds.set_defaults(fn=cmd_commands)

    p_status = sub.add_parser("status", help="show goal, agents, ledger tail")
    p_status.set_defaults(fn=cmd_status)

    p_watch = sub.add_parser("watch", help="live view of ledger entries as they land")
    p_watch.set_defaults(fn=cmd_watch)

    p_say = sub.add_parser("say", help="add an Owner note — the crew's top-priority instruction")
    p_say.add_argument("message", nargs="+", help="what to tell the crew")
    p_say.add_argument("--title", default="Guidance", help='entry title (default "Guidance")')
    p_say.add_argument("--to", default=None, metavar="AGENT",
                       help="address one specific agent instead of the whole crew")
    p_say.set_defaults(fn=cmd_say)

    p_rule = sub.add_parser("rule", help="standing behavioral rule for ONE agent, binding every turn")
    p_rule.add_argument("agent", help="which agent the rule binds")
    p_rule.add_argument("text", nargs="+", help="the rule")
    p_rule.set_defaults(fn=cmd_rule)

    p_stop = sub.add_parser("stop", help="halt a running crew after the current turn")
    p_stop.add_argument("reason", nargs="*", help="optional reason, recorded in the ledger")
    p_stop.set_defaults(fn=cmd_stop)

    p_goal = sub.add_parser("goal", help="show the goal, or set a new one (crew keeps its memory)")
    p_goal.add_argument("text", nargs="*", help="the new goal; empty = show current")
    p_goal.set_defaults(fn=cmd_goal)

    p_ask = sub.add_parser("ask", help='one-shot question to the crew: communicate ask "is X true?"')
    p_ask.add_argument("question", nargs="+", help="what you want to know")
    p_ask.add_argument("--agent", default=None, help="which agent answers (default: first)")
    p_ask.set_defaults(fn=cmd_ask)

    p_inbox = sub.add_parser("inbox", help="what an agent must respond to (mentions, verdicts, Owner notes)")
    p_inbox.add_argument("agent", help="agent name (or Owner)")
    p_inbox.set_defaults(fn=cmd_inbox)

    p_compact = sub.add_parser("compact", help="fold ledger history into the digest (token-efficient boots)")
    p_compact.set_defaults(fn=cmd_compact)

    p_archive = sub.add_parser("archive", help="relocate pre-digest entries to a JSONL archive (lossless)")
    p_archive.set_defaults(fn=cmd_archive)

    p_history = sub.add_parser("history", help="search live ledger + archives")
    p_history.add_argument("query", nargs="+", help="text to search for (case-insensitive)")
    p_history.set_defaults(fn=cmd_history)

    p_add = sub.add_parser("add-agent", help="add an agent to the crew (auto-named Agent3, Agent4, …)")
    p_add.add_argument("--name", default=None, help="agent name (default: next free AgentN)")
    p_add.add_argument("--role", default=None, help='e.g. "Tester", "Docs" (default Collaborator)')
    p_add.add_argument("--brief", default=None, help="one-line working contract")
    p_add.add_argument("--cli", default=None, help="claude / codex / aider / gemini (default: first detected)")
    p_add.add_argument("--model", default=None, help="model override for that CLI")
    p_add.add_argument("--command", default=None, help="raw command with {prompt} (overrides --cli)")
    p_add.set_defaults(fn=cmd_add_agent)

    p_claim = sub.add_parser("claim", help="claim an agent identity in the ledger (free-running agents)")
    p_claim.add_argument("name", help="unique agent name to claim")
    p_claim.add_argument("--role", default="Collaborator", help='e.g. "Implementer", "Reviewer"')
    p_claim.add_argument("--brief", default="", help="one-line working contract for this agent")
    p_claim.set_defaults(fn=cmd_claim)

    p_da = sub.add_parser("_demo-agent")  # internal: a scripted demo agent turn
    p_da.add_argument("name")
    p_da.add_argument("prompt", nargs="?")
    p_da.set_defaults(fn=cmd_demo_agent)

    args = parser.parse_args()
    if args.cmd is None:
        if sys.stdin.isatty() and find_config(Path.cwd()) is not None:
            cmd_watch(args)          # a crewed project opens the cockpit
            return
        cmd_overview()
        if sys.stdin.isatty():
            interactive(parser)      # crewless: onboarding session
        return
    args.fn(args)


def interactive(parser: argparse.ArgumentParser) -> None:
    """Bare `communicate` on a real terminal opens a session: type commands
    without the `communicate` prefix; the session survives command errors."""
    print("\ninteractive session — type commands without the 'communicate' "
          "prefix\n(e.g. run · watch · say hold on · status · inbox Kestrel · "
          "help · quit)\n")
    while True:
        try:
            line = input("communicate> ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            return
        if not line:
            continue
        if line in ("quit", "exit", "q"):
            return
        if line in ("help", "?", "commands"):
            cmd_commands()
            continue
        try:
            tokens = shlex.split(line)
        except ValueError as exc:
            print(f"  parse error: {exc}")
            continue
        if tokens[0] == "communicate":   # muscle memory is fine too
            tokens = tokens[1:]
        if not tokens:
            continue
        try:
            args = parser.parse_args(tokens)
        except SystemExit:               # argparse's error/help exit
            continue
        if args.cmd is None:
            cmd_overview()
            continue
        try:
            args.fn(args)
        except SystemExit:               # die() inside a command
            continue
        except KeyboardInterrupt:
            print("\n  (interrupted — session still open)")
        print()


