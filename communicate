              f"the rest of the crew sees it but knows it is not theirs.")
    else:
        append_entry(ledger, "Owner", args.title, message)
        print(f'noted in the ledger as "## Owner — {args.title}".')
        print("every agent reads the ledger at the start of its turn and treats")
        print("the newest Owner entry as its top-priority instruction.")


