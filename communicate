    i = 1
    while f"Agent{i}" in names:
        i += 1
    return f"Agent{i}"


def cmd_add_agent(args: argparse.Namespace) -> None:
    root = Path.cwd()
    cfg_path = find_config(root)
    if cfg_path is None:
        die("no crew here — run `communicate init` first")
    cfg = load_config(root)
    names = _crew_names(cfg)

    name = (args.name or next_agent_name(names)).strip()
    if name == "Owner":
        die('"Owner" is reserved for the human')
    if " " in name:
        die("agent names cannot contain spaces (@mentions and ledger parsing "
            "need single tokens) — use Agent3, not 'Agent 3'")
    if name in names:
        die(f"{name!r} is taken — crew: {', '.join(names)}")

    command = args.command
    cli_name = args.cli
    if not command:
        clis = dict(KNOWN_AGENT_CLIS)
        if cli_name:
            if cli_name not in clis:
                die(f"unknown --cli {cli_name!r}; known: {', '.join(clis)}")
            command = clis[cli_name]
        else:
            detected = detect_agent_clis()
            if not detected:
                die("no known agent CLI on PATH — pass "
                    "--command 'your-cli {prompt}'")
            cli_name, command = detected[0]
        if args.model:
            command += f" {MODEL_FLAGS.get(cli_name, '--model')} {args.model}"
    if "{prompt}" not in command:
        die("the command must contain {prompt}")
    if "'" in command:
        die("command contains a single quote — add this agent by editing "
            f"{cfg_path} directly")

    role = args.role or "Collaborator"
    brief = (args.brief or "").replace('"', "'")
    block = ('\n[[agents]]\nname = "%s"\nrole = "%s"\nbrief = "%s"\n'
             "command = '%s'\n" % (name, role, brief, command))
    with cfg_path.open("a") as fh:
        fh.write(block)
    crew = ", ".join(names + [name])
    print(f"added {name} ({role}, {cli_name or 'custom command'}) → {cfg_path}")
    print(f"crew is now: {crew}")
    print("tip: give each agent a distinct territory in its brief, and with 3+")
    print("     agents wire explicit review pairs — broadcast review requests")
    print("     produce nobody reviewing (SPEC §3.2).")


def cmd_goal(args: argparse.Namespace) -> None:
    root = Path.cwd()
    cfg_path = find_config(root)
    if cfg_path is None:
        die("no crew here — run `communicate init` first")
    cfg = load_config(root)
    new_goal = " ".join(args.text).strip()
    if not new_goal:
        print(paint("current goal:", "1;36"))
        print("  " + cfg["goal"].strip().replace("\n", "\n  "))
        print(paint('\nset a new one: ', "2") + paint('communicate goal', "1;92")
              + paint(' "refactor the auth module, tests green"', "33"))
        return
    if '"""' in new_goal:
        die('the goal cannot contain a triple quote (\"\"\")')
    text = cfg_path.read_text()
    new_text, n = re.subn(r'goal\s*=\s*""".*?"""',
                          'goal = """\n' + new_goal + '\n"""',
                          text, count=1, flags=re.DOTALL)
    if n == 0:
        new_text, n = re.subn(r'goal\s*=\s*"[^"\n]*"',
                              'goal = """\n' + new_goal + '\n"""',
                              text, count=1)
    if n == 0:
        die(f"could not find a goal assignment in {cfg_path} — edit it directly")
    cfg_path.write_text(new_text)
    ledger = root / cfg["ledger"]
    if ledger.exists():
        append_entry(ledger, "Owner", "New goal set", new_goal)
    print(paint("new goal set", "1;92") + paint(f" (recorded in {cfg['ledger']} — the crew", "2"))
    print(paint("keeps all project memory; completion of the old goal no longer", "2"))
    print(paint("counts). Start work: ", "2") + paint("communicate run", "1;92"))


