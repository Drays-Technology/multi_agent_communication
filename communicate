#!/usr/bin/env python3
"""communicate — run multiple AI agents toward one goal via a shared ledger.

The runner does deliberately little: it schedules turns and hands each agent
its identity, role, the goal, and the ledger path. The agents do real work in
the working directory and coordinate by appending entries to the ledger, per
the communicate.md protocol (SPEC.md). The ledger — not this process — is the
source of truth, so a crashed run resumes by simply running again.

Usage:
    communicate demo              watch two built-in agents collaborate
                                  (no API keys, finishes in seconds)
    communicate init              guided setup: goal + agents -> crew.toml
    communicate run               run agents until GOAL-COMPLETE is APPROVED
    communicate run --rounds 5    override max rounds
    communicate status            show goal, agents, and the ledger tail

  You are the crew's conscience — watch them, guide them, stop them:
    communicate watch             live view of ledger entries as they land
    communicate say <message>     add an Owner note; agents treat the newest
                                  Owner entry as their top-priority instruction
    communicate stop [reason]     tell a running crew to halt after the
                                  current turn

Requires Python 3.11+ (stdlib only).
"""

from __future__ import annotations

import argparse
import datetime
import re
import shlex
import shutil
import subprocess
import sys
import time
import tomllib
from pathlib import Path

CONFIG = "crew.toml"

# ── templates ────────────────────────────────────────────────────────────────

CONFIG_TEMPLATE = """\
# communicate.md crew — agents working toward one goal via a shared ledger.

goal = \"\"\"
{goal}
\"\"\"

ledger = "communicate.md"
max_rounds = {max_rounds}          # safety stop; a round = one turn for every agent
timeout_minutes = 30     # per agent turn

# Each agent is any command that accepts a prompt and can read/write files
# in this directory. {{prompt}} is replaced with the turn prompt.

[[agents]]
name = "{a1_name}"
role = "Implementer"
brief = "You build. Ship small verified steps; ask for review via the ledger."
command = '{a1_command}'

[[agents]]
name = "{a2_name}"
role = "Reviewer"
brief = "You verify. Review diffs and behavior, not summaries. Issue verdicts."
command = '{a2_command}'
"""

DEFAULT_GOAL = """Replace this with the goal. Be specific: what done looks
like, constraints, and anything the agents must not do without asking the
owner."""

LEDGER_TEMPLATE = """\
# communicate.md — shared ledger

<!-- Append-only. Entries: ## <Agent> — <Title> (<YYYY-MM-DD>).
     Protocol: https://github.com/Drays-Technology/multi_agent_communication -->

## Owner — Goal set ({date})

{goal}
"""

TURN_PROMPT = """\
You are the agent "{name}" (role: {role}) in a multi-agent collaboration
governed by the communicate.md protocol. {brief}

THE SHARED GOAL:
{goal}

THE LEDGER: ./{ledger} — read its tail FIRST; your collaborators' latest
entries, verdicts, and review asks are there.

YOUR INBOX — entries written since your last turn, tagged where they demand
something of you (this digest is computed, but READ THE FULL ENTRIES in the
ledger before acting):
{inbox}

THE OWNER'S STANDING RULES FOR YOU — these bind on every turn until the
Owner posts a newer rule changing them (newest wins on conflict):
{standing_rules}

Protocol rules, short form:

- Do real work toward the goal in this directory this turn (write code, run
  tests, review diffs — whatever your role calls for). Prefer one meaningful
  verified step over many unverified ones.
- Then append exactly ONE entry to ./{ledger}:
  "## {name} — <specific title> ({date})" describing what you did, what you
  found, and any verdicts. Use the verdict words when they apply:
  PROPOSED / APPROVED / BLOCKING / COUNTER-REVIEW / ENDORSED / DISPOSITIONED.
- Never edit or delete existing entries; correct mistakes by superseding.
- Never approve your own change; review actual diffs/behavior, not summaries.
- Address your inbox before starting new work: a PROPOSED or COUNTER-REVIEW
  by a collaborator needs your verdict; a BLOCKING finding on your work needs
  a fix or a rebuttal with evidence.
- To direct a question or ask at a specific collaborator, @mention them by
  name (write "@" + their exact agent name). Mentions land in the
  addressee's inbox; unaddressed questions land nowhere.
- Entries signed "Owner" are the human's voice. The NEWEST Owner entry is
  your highest-priority instruction — it may add constraints, redirect your
  work, or amend the goal itself. Acknowledge it in your entry when you act
  on it.
- Anything irreversible or outside the goal's stated constraints: do NOT do
  it — record it as "pending owner" in your entry instead.

Ending the collaboration:
- If you believe the goal is fully met AND you have verified it, title your
  entry "## {name} — GOAL-COMPLETE: <one-line summary>".
- If a collaborator claimed GOAL-COMPLETE and your own verification agrees,
  title yours "## {name} — APPROVED: GOAL-COMPLETE". The run stops only on
  that pair, so do not approve lightly.

This is round {round} of at most {max_rounds}.
"""

# Agent CLIs the init wizard knows how to wire up, in preference order.
KNOWN_AGENT_CLIS = [
    ("claude", "claude -p {prompt} --permission-mode acceptEdits"),
    ("aider", "aider --message {prompt} --yes-always"),
]


# ── helpers ──────────────────────────────────────────────────────────────────

def die(msg: str) -> None:
    print(f"communicate: {msg}", file=sys.stderr)
    sys.exit(1)


def today() -> str:
    return datetime.date.today().isoformat()


def load_config(root: Path) -> dict:
    path = root / CONFIG
    if not path.exists():
        die(f"{CONFIG} not found — run `communicate init` first "
            f"(or `communicate demo` to see how this works)")
    with path.open("rb") as fh:
        cfg = tomllib.load(fh)
    for key in ("goal", "agents"):
        if key not in cfg:
            die(f"{CONFIG} missing required key: {key}")
    if len(cfg["agents"]) < 2:
        die("at least two agents are required — peer review needs a peer")
    names = [a["name"] for a in cfg["agents"]]
    if len(names) != len(set(names)):
        die(f"agent names must be unique, got: {names}")
    if "Owner" in names:
        die('"Owner" is reserved for the human — rename that agent')
    cfg.setdefault("ledger", "communicate.md")
    cfg.setdefault("max_rounds", 12)
    cfg.setdefault("timeout_minutes", 30)
    return cfg


def entry_headings(ledger_text: str) -> list[str]:
    return re.findall(r"^## .*$", ledger_text, re.MULTILINE)


def goal_complete(ledger_text: str, agent_names: list[str]) -> bool:
    """Done = one agent claimed GOAL-COMPLETE and a DIFFERENT agent approved."""
    claimers = set(
        re.findall(r"^## (\S+) — GOAL-COMPLETE", ledger_text, re.MULTILINE)
    )
    approvers = set(
        re.findall(r"^## (\S+) — APPROVED: GOAL-COMPLETE", ledger_text, re.MULTILINE)
    )
    claimers &= set(agent_names)
    approvers &= set(agent_names)
    return bool(claimers) and bool(approvers - claimers)


def append_entry(ledger: Path, agent: str, title: str, body: str) -> None:
    with ledger.open("a") as fh:
        fh.write(f"\n## {agent} — {title} ({today()})\n\n{body.rstrip()}\n")


def owner_stop_count(ledger_text: str) -> int:
    return len(re.findall(r"^## Owner — STOP", ledger_text, re.MULTILINE))


def split_entries_by_author(ledger_text: str) -> list[tuple[str, str]]:
    """[(author, whole_entry), ...] in ledger order."""
    out = []
    for entry in re.split(r"(?m)^(?=## )", ledger_text):
        m = re.match(r"^## (\S+) — ", entry)
        if m:
            out.append((m.group(1), entry.rstrip()))
    return out


def standing_rules(ledger_text: str, agent_name: str) -> list[str]:
    """All Owner 'Standing rule for @X' bodies for this agent, in order.

    Rules bind until the Owner posts a newer rule changing them — so they
    are injected into EVERY turn prompt, unlike inbox items, which drop out
    of the digest once the agent has taken a turn.
    """
    rules = []
    pattern = re.compile(rf"— Standing rule for @{re.escape(agent_name)}\b")
    for author, entry in split_entries_by_author(ledger_text):
        if author != "Owner":
            continue
        lines = entry.splitlines()
        if pattern.search(lines[0]):
            body = "\n".join(lines[1:]).strip()
            if body:
                rules.append(body)
    return rules


def compute_inbox(ledger_text: str, agent_name: str) -> list[str]:
    """What this agent must see before working: every entry since its own
    last entry, tagged when it demands something of the agent.

    Tags: [MENTIONS YOU]      — contains @agent_name
          [NEEDS YOUR REVIEW] — PROPOSED / COUNTER-REVIEW by someone else
          [BLOCKING]          — a blocking finding (fix or rebut)
          [OWNER]             — the human spoke; top priority
    """
    entries = split_entries_by_author(ledger_text)
    last_own = -1
    for i, (author, _) in enumerate(entries):
        if author == agent_name:
            last_own = i
    digest = []
    mention = f"@{agent_name}"
    for author, entry in entries[last_own + 1:]:
        if author == agent_name:
            continue
        heading = entry.splitlines()[0]
        tags = []
        if author == "Owner":
            tags.append("[OWNER]")
        if mention in entry:
            tags.append("[MENTIONS YOU]")
        if re.search(r"— (PROPOSED|COUNTER-REVIEW)", heading):
            tags.append("[NEEDS YOUR REVIEW]")
        if "— BLOCKING" in heading:
            tags.append("[BLOCKING]")
        digest.append(f"{' '.join(tags) + ' ' if tags else ''}{heading}")
    return digest


# ── init (wizard) ────────────────────────────────────────────────────────────

def detect_agent_clis() -> list[tuple[str, str]]:
    return [(name, cmd) for name, cmd in KNOWN_AGENT_CLIS if shutil.which(name)]


def ask(prompt: str, default: str = "") -> str:
    suffix = f" [{default}]" if default else ""
    answer = input(f"{prompt}{suffix}: ").strip()
    return answer or default


def cmd_init(args: argparse.Namespace) -> None:
    root = Path.cwd()
    cfg_path = root / CONFIG
    if cfg_path.exists() and not args.force:
        die(f"{CONFIG} already exists (use --force to overwrite)")

    goal = DEFAULT_GOAL
    a1_name, a2_name = "Kestrel", "Heron"
    fallback = "your-agent-cli {prompt}"
    a1_command = a2_command = fallback

    interactive = sys.stdin.isatty() and not args.defaults
    if interactive:
        print("communicate init — set up a crew in 3 questions. "
              "(Enter accepts the [default].)\n")

        print("1) What is the goal? Be specific about what 'done' looks like.")
        print("   Type it below; finish with an empty line.")
        lines: list[str] = []
        while True:
            line = input("   > ")
            if not line.strip() and lines:
                break
            if line.strip():
                lines.append(line)
        goal = "\n".join(lines)

        detected = detect_agent_clis()
        print("\n2) Which agent CLI should power the crew?")
        if detected:
            for i, (name, cmd) in enumerate(detected, 1):
                print(f"   {i}. {name}  ({cmd})")
            print(f"   {len(detected) + 1}. other (edit crew.toml afterward)")
            choice = ask("   pick a number", "1")
            try:
                a1_command = a2_command = detected[int(choice) - 1][1]
            except (ValueError, IndexError):
                a1_command = a2_command = fallback
        else:
            print("   No known agent CLI found on PATH (looked for: "
                  + ", ".join(n for n, _ in KNOWN_AGENT_CLIS) + ").")
            print(f"   Writing a placeholder — edit `command` in {CONFIG} before running.")

        print("\n3) Name the agents (they sign the ledger with these).")
        a1_name = ask("   implementer name", a1_name)
        a2_name = ask("   reviewer name", a2_name)
        if a2_name == a1_name:
            a2_name = a1_name + "-2"
            print(f"   names must differ — reviewer renamed to {a2_name}")

    cfg_path.write_text(CONFIG_TEMPLATE.format(
        goal=goal, max_rounds=12,
        a1_name=a1_name, a1_command=a1_command,
        a2_name=a2_name, a2_command=a2_command,
    ))
    ledger = root / "communicate.md"
    if not ledger.exists():
        ledger.write_text(LEDGER_TEMPLATE.format(date=today(), goal=goal))

    print(f"\nwrote {CONFIG} and communicate.md")
    if interactive and (a1_command != fallback):
        print("next: `communicate run`  (each turn invokes your agent CLI — "
              "normal API charges apply)")
    else:
        print(f"next: edit {CONFIG} (goal + agent commands), then `communicate run`")


# ── run ──────────────────────────────────────────────────────────────────────

def run_turn(agent: dict, cfg: dict, round_no: int, log_dir: Path, ledger: Path) -> None:
    ledger_text = ledger.read_text() if ledger.exists() else ""
    inbox = compute_inbox(ledger_text, agent["name"])
    inbox_text = "\n".join(f"- {line}" for line in inbox) if inbox else \
        "- (nothing new since your last turn)"
    rules = standing_rules(ledger_text, agent["name"])
    rules_text = "\n".join(f"- {r}" for r in rules) if rules else "- (none)"
    prompt = TURN_PROMPT.format(
        name=agent["name"],
        role=agent.get("role", "Collaborator"),
        brief=agent.get("brief", ""),
        goal=cfg["goal"].strip(),
        ledger=cfg["ledger"],
        inbox=inbox_text,
        standing_rules=rules_text,
        date=today(),
        round=round_no,
        max_rounds=cfg["max_rounds"],
    )
    argv = [
        prompt if token == "{prompt}" else token
        for token in shlex.split(agent["command"])
    ]
    if prompt not in argv:
        die(f"agent {agent['name']}: command must contain {{prompt}}")
    log_path = log_dir / f"round{round_no:02d}-{agent['name']}.log"
    before = entry_headings(ledger.read_text()) if ledger.exists() else []
    print(f"  ▸ {agent['name']} ({agent.get('role', '?')}) working … "
          f"(watch: tail -f {log_path})", flush=True)
    started = time.monotonic()
    try:
        with log_path.open("w") as log:
            subprocess.run(
                argv, stdout=log, stderr=subprocess.STDOUT,
                timeout=cfg["timeout_minutes"] * 60, check=False,
            )
        elapsed = time.monotonic() - started
        after = entry_headings(ledger.read_text()) if ledger.exists() else []
        new = after[len(before):]
        if new:
            for heading in new:
                print(f"    ↳ {heading}")
        else:
            print(f"    ↳ (no ledger entry written — see {log_path})")
        print(f"    {elapsed:.0f}s")
    except subprocess.TimeoutExpired:
        print(f"    ↳ TIMEOUT after {cfg['timeout_minutes']}m (log: {log_path})")
    except FileNotFoundError:
        die(f"agent {agent['name']}: command not found: {argv[0]}")


def cmd_run(args: argparse.Namespace) -> None:
    root = Path.cwd()
    cfg = load_config(root)
    if args.rounds:
        cfg["max_rounds"] = args.rounds
    ledger = root / cfg["ledger"]
    if not ledger.exists():
        die(f"ledger {cfg['ledger']} not found — run `communicate init`")
    log_dir = root / ".communicate" / "logs"
    log_dir.mkdir(parents=True, exist_ok=True)
    names = [a["name"] for a in cfg["agents"]]

    roster = ", ".join(
        "{}({})".format(a["name"], a.get("role", "?")) for a in cfg["agents"]
    )
    print(f"goal: {cfg['goal'].strip().splitlines()[0]} …")
    print(f"agents: {roster}")
    print("you: `communicate watch` to observe, `communicate say <msg>` to "
          "guide, `communicate stop` to halt\n")

    stops_at_launch = owner_stop_count(ledger.read_text())
    for round_no in range(1, cfg["max_rounds"] + 1):
        print(f"round {round_no}/{cfg['max_rounds']}")
        for agent in cfg["agents"]:
            run_turn(agent, cfg, round_no, log_dir, ledger)
            text = ledger.read_text()
            if goal_complete(text, names):
                print("\n✓ GOAL-COMPLETE claimed and independently APPROVED — stopping.")
                print(f"  read the full story: {ledger}")
                return
            if owner_stop_count(text) > stops_at_launch:
                print("\n■ Owner said STOP — halting after this turn.")
                print(f"  the ledger holds the state: {ledger} — re-run to continue.")
                return
    print(f"\nmax rounds ({cfg['max_rounds']}) reached without an approved "
          f"GOAL-COMPLETE. The ledger holds the state — re-run to continue.")


# ── status ───────────────────────────────────────────────────────────────────

def cmd_status(_: argparse.Namespace) -> None:
    root = Path.cwd()
    cfg = load_config(root)
    ledger = root / cfg["ledger"]
    roster = ", ".join(
        "{}({})".format(a["name"], a.get("role", "?")) for a in cfg["agents"]
    )
    print(f"goal: {cfg['goal'].strip()}")
    print(f"agents: {roster}")
    if ledger.exists():
        text = ledger.read_text()
        entries = entry_headings(text)
        print(f"ledger: {len(entries)} entries; last 5:")
        for line in entries[-5:]:
            print(f"  {line}")
        names = [a["name"] for a in cfg["agents"]]
        print(f"complete: {'YES' if goal_complete(text, names) else 'no'}")
    else:
        print("ledger: (missing)")


# ── owner interface: watch / say / stop ─────────────────────────────────────
# The human is the crew's conscience. These commands need no running process
# to coordinate with — they read and append the same ledger the agents use,
# which is the whole point of the protocol.

VERDICT_COLORS = [
    ("BLOCKING", "\033[31m"),        # red
    ("APPROVED: GOAL-COMPLETE", "\033[92m"),
    ("GOAL-COMPLETE", "\033[92m"),   # bright green
    ("APPROVED", "\033[32m"),        # green
    ("COUNTER-REVIEW", "\033[35m"),  # magenta
    ("PROPOSED", "\033[33m"),        # yellow
    ("STOP", "\033[31m"),
]
RESET = "\033[0m"
BOLD = "\033[1m"
DIM = "\033[2m"


def colorize_heading(heading: str, use_color: bool) -> str:
    if not use_color:
        return heading
    for keyword, color in VERDICT_COLORS:
        if f"— {keyword}" in heading or f"— {keyword}:" in heading:
            return f"{color}{BOLD}{heading}{RESET}"
    if heading.startswith("## Owner"):
        return f"\033[36m{BOLD}{heading}{RESET}"  # cyan: the human's voice
    return f"{BOLD}{heading}{RESET}"


def split_entries(ledger_text: str) -> list[str]:
    """The ledger as a list of whole entries (heading + body)."""
    parts = re.split(r"(?m)^(?=## )", ledger_text)
    return [p.rstrip() for p in parts if p.startswith("## ")]


def cmd_watch(_: argparse.Namespace) -> None:
    root = Path.cwd()
    cfg = load_config(root)
    ledger = root / cfg["ledger"]
    if not ledger.exists():
        die(f"ledger {cfg['ledger']} not found")
    use_color = sys.stdout.isatty()
    seen = 0
    print(f"watching {ledger} — Ctrl-C to leave.")
    print(f"{DIM if use_color else ''}guide the crew anytime: "
          f"`communicate say <message>` / `communicate stop`"
          f"{RESET if use_color else ''}\n")
    entries = split_entries(ledger.read_text())
    # Show the last few immediately so the watcher has context…
    for entry in entries[-3:]:
        heading, _, body = entry.partition("\n")
        print(colorize_heading(heading, use_color))
        print(body.strip() + "\n" if body.strip() else "")
    seen = len(entries)
    # …then stream everything new.
    try:
        while True:
            time.sleep(1.0)
            entries = split_entries(ledger.read_text())
            for entry in entries[seen:]:
                heading, _, body = entry.partition("\n")
                print(colorize_heading(heading, use_color))
                print(body.strip() + "\n" if body.strip() else "")
            seen = max(seen, len(entries))
    except KeyboardInterrupt:
        print("\nleft the room — the crew keeps working. "
              "`communicate status` for a summary anytime.")


def _crew_names(cfg: dict) -> list[str]:
    return [a["name"] for a in cfg["agents"]]


def cmd_say(args: argparse.Namespace) -> None:
    root = Path.cwd()
    cfg = load_config(root)
    ledger = root / cfg["ledger"]
    if not ledger.exists():
        die(f"ledger {cfg['ledger']} not found")
    message = " ".join(args.message).strip()
    if not message:
        die('nothing to say — usage: communicate say "focus on the API tests first"')
    if args.to:
        if args.to not in _crew_names(cfg):
            die(f"no agent named {args.to!r} — crew: {', '.join(_crew_names(cfg))}")
        title = f"Directive for @{args.to}"
        append_entry(ledger, "Owner", title, message)
        print(f'directive posted as "## Owner — {title}".')
        print(f"it lands in {args.to}'s inbox tagged [OWNER] [MENTIONS YOU]; "
              f"the rest of the crew sees it but knows it is not theirs.")
    else:
        append_entry(ledger, "Owner", args.title, message)
        print(f'noted in the ledger as "## Owner — {args.title}".')
        print("every agent reads the ledger at the start of its turn and treats")
        print("the newest Owner entry as its top-priority instruction.")


def cmd_rule(args: argparse.Namespace) -> None:
    root = Path.cwd()
    cfg = load_config(root)
    ledger = root / cfg["ledger"]
    if not ledger.exists():
        die(f"ledger {cfg['ledger']} not found")
    if args.agent not in _crew_names(cfg):
        die(f"no agent named {args.agent!r} — crew: {', '.join(_crew_names(cfg))}")
    text = " ".join(args.text).strip()
    if not text:
        die('empty rule — usage: communicate rule Kestrel "never touch the db schema"')
    append_entry(ledger, "Owner", f"Standing rule for @{args.agent}", text)
    rules = standing_rules(ledger.read_text(), args.agent)
    print(f"standing rule recorded — {args.agent} now carries "
          f"{len(rules)} rule{'s' if len(rules) != 1 else ''}, injected into "
          f"EVERY future turn (not just the next one).")
    print("to change or lift a rule, post a newer one saying so — newest wins.")


def cmd_claim(args: argparse.Namespace) -> None:
    """Claim an agent identity in the ledger (for free-running agents that
    work OUTSIDE `communicate run` — under the runner, crew.toml assigns
    identity and this is unnecessary)."""
    root = Path.cwd()
    ledger = root / "communicate.md"
    cfg_path = root / CONFIG
    if cfg_path.exists():
        with cfg_path.open("rb") as fh:
            ledger = root / tomllib.load(fh).get("ledger", "communicate.md")
    if not ledger.exists():
        die(f"no ledger at {ledger} — create one or run `communicate init`")
    if args.name == "Owner":
        die('"Owner" is reserved for the human')
    text = ledger.read_text()
    claimed = {author for author, _ in split_entries_by_author(text)}
    if args.name in claimed:
        die(f"{args.name!r} is already claimed in this ledger — "
            f"taken: {', '.join(sorted(claimed))}. Pick another name.")
    body = f"Role: {args.role}."
    if args.brief:
        body += f" {args.brief}"
    body += ("\n\nChecked the ledger for existing claims before taking this "
             "name, per SPEC §3.1.")
    append_entry(ledger, args.name, f"Claiming role: {args.role}", body)
    print(f"claimed {args.name!r} ({args.role}) in {ledger}.")
    print("sign every entry with this exact name; others @mention you with it.")


def cmd_inbox(args: argparse.Namespace) -> None:
    root = Path.cwd()
    cfg = load_config(root)
    ledger = root / cfg["ledger"]
    if not ledger.exists():
        die(f"ledger {cfg['ledger']} not found")
    known = [a["name"] for a in cfg["agents"]] + ["Owner"]
    if args.agent not in known:
        die(f"unknown agent {args.agent!r} — crew: {', '.join(known)}")
    digest = compute_inbox(ledger.read_text(), args.agent)
    if not digest:
        print(f"{args.agent}: inbox empty — nothing new since their last entry.")
        return
    print(f"{args.agent}: {len(digest)} entr{'y' if len(digest) == 1 else 'ies'} "
          f"since their last turn:")
    for line in digest:
        print(f"  - {line}")


def cmd_stop(args: argparse.Namespace) -> None:
    root = Path.cwd()
    cfg = load_config(root)
    ledger = root / cfg["ledger"]
    if not ledger.exists():
        die(f"ledger {cfg['ledger']} not found")
    reason = " ".join(args.reason).strip() or "Halt after the current turn."
    append_entry(ledger, "Owner", "STOP", reason)
    print("STOP posted — a running crew halts after the turn in progress.")
    print("re-run `communicate run` to continue later; the ledger keeps the state.")


# ── demo ─────────────────────────────────────────────────────────────────────
# Two built-in agents collaborate on a tiny real task (fizzbuzz) using the
# REAL run loop. No API keys. The implementer ships a genuinely buggy first
# version; the reviewer actually executes the code, catches it, and issues a
# BLOCKING finding — so the demo shows the protocol's whole point.

BUGGY_FIZZBUZZ = '''\
def fizzbuzz(n: int) -> str:
    if n % 3 == 0:
        return "Fizz"
    if n % 5 == 0:
        return "Buzz"
    if n % 15 == 0:
        return "FizzBuzz"
    return str(n)


if __name__ == "__main__":
    for i in range(1, 21):
        print(fizzbuzz(i))
'''

FIXED_FIZZBUZZ = '''\
def fizzbuzz(n: int) -> str:
    if n % 15 == 0:
        return "FizzBuzz"
    if n % 3 == 0:
        return "Fizz"
    if n % 5 == 0:
        return "Buzz"
    return str(n)


if __name__ == "__main__":
    for i in range(1, 21):
        print(fizzbuzz(i))
'''


def run_fizzbuzz(root: Path) -> tuple[str, str]:
    """Execute the demo's fizzbuzz.py; return (line15, full output)."""
    result = subprocess.run(
        [sys.executable, "fizzbuzz.py"], cwd=root,
        capture_output=True, text=True, timeout=10,
    )
    lines = result.stdout.splitlines()
    return (lines[14] if len(lines) >= 15 else "", result.stdout)


def demo_agent_turn(name: str, root: Path) -> None:
    """Scripted-but-real agent: acts on the ACTUAL ledger + files each turn."""
    ledger = root / "communicate.md"
    text = ledger.read_text()
    src = root / "fizzbuzz.py"

    if name == "Kestrel":
        if "## Kestrel — PROPOSED" not in text:
            src.write_text(BUGGY_FIZZBUZZ)
            append_entry(ledger, "Kestrel", "PROPOSED: fizzbuzz.py first cut",
                "Wrote `fizzbuzz.py` (classic rules, printed for 1-20).\n"
                "Ran it — output looks right at a glance.\n\n"
                "**Review ask:** behavior check before we call the goal met.")
        elif "## Heron — BLOCKING" in text and "## Kestrel — COUNTER-REVIEW" not in text:
            src.write_text(FIXED_FIZZBUZZ)
            line15, _ = run_fizzbuzz(root)
            append_entry(ledger, "Kestrel", "COUNTER-REVIEW: divisibility order fixed",
                "You were right — the `% 15` check was unreachable below the\n"
                "`% 3` branch. Reordered most-specific-first and re-ran:\n"
                f"line 15 now prints `{line15}`. Review me back.")
        elif "## Heron — APPROVED: fix verified" in text and "GOAL-COMPLETE" not in text:
            _, output = run_fizzbuzz(root)
            append_entry(ledger, "Kestrel", "GOAL-COMPLETE: fizzbuzz verified",
                "Full run 1-20 checked against the rules line by line —\n"
                "all correct. Claiming the goal; needs your independent\n"
                "approval to close.")

    if name == "Heron":
        if "## Kestrel — PROPOSED" in text and "## Heron — BLOCKING" not in text:
            line15, _ = run_fizzbuzz(root)
            if line15 != "FizzBuzz":
                append_entry(ledger, "Heron", "BLOCKING: 15 prints the wrong thing",
                    "Reviewed by EXECUTION, not by reading the summary.\n\n"
                    "**Defect:** the `% 15` branch sits below `% 3`, so it can\n"
                    "never be reached.\n"
                    f"**Failure scenario:** input 15 → prints `{line15}`, "
                    "spec says `FizzBuzz`.\n"
                    "**Fix shape I'd approve:** most-specific divisor first.")
        elif "## Kestrel — COUNTER-REVIEW" in text and "## Heron — APPROVED: fix verified" not in text:
            line15, _ = run_fizzbuzz(root)
            verdict = ("APPROVED: fix verified" if line15 == "FizzBuzz"
                       else "BLOCKING: still wrong")
            append_entry(ledger, "Heron", verdict,
                f"Re-executed `fizzbuzz.py`: line 15 → `{line15}`. "
                "Checked the diff too — order is most-specific-first. No findings.")
        elif "## Kestrel — GOAL-COMPLETE" in text and "## Heron — APPROVED: GOAL-COMPLETE" not in text:
            line15, _ = run_fizzbuzz(root)
            if line15 == "FizzBuzz":
                append_entry(ledger, "Heron", "APPROVED: GOAL-COMPLETE",
                    "Independent final verification: executed the program, "
                    "checked all 20 lines against the rules. Goal met.")


def cmd_demo(_: argparse.Namespace) -> None:
    import os

    root = Path.cwd() / "communicate-demo"
    if root.exists():
        shutil.rmtree(root)
    root.mkdir()

    goal = ("Write fizzbuzz.py (print 1-20 with the classic rules) and get it "
            "verified by execution, not by trust.")
    (root / "communicate.md").write_text(
        LEDGER_TEMPLATE.format(date=today(), goal=goal)
    )
    me = shlex.quote(str(Path(__file__).resolve()))
    py = shlex.quote(sys.executable)
    (root / CONFIG).write_text(CONFIG_TEMPLATE.format(
        goal=goal, max_rounds=4,
        a1_name="Kestrel", a1_command=f"{py} {me} _demo-agent Kestrel {{prompt}}",
        a2_name="Heron", a2_command=f"{py} {me} _demo-agent Heron {{prompt}}",
    ))

    print("communicate demo — two built-in agents, one goal, zero API keys.")
    print("Kestrel implements; Heron reviews BY EXECUTING the code.")
    print(f"Everything happens in ./{root.name}/ — recreated each demo.\n")

    old = Path.cwd()
    os.chdir(root)
    try:
        cmd_run(argparse.Namespace(rounds=None))
    finally:
        os.chdir(old)

    print(f"\nWhat just happened (full story: {root / 'communicate.md'}):")
    print("  1. Kestrel shipped fizzbuzz.py with a REAL bug (unreachable %15 branch)")
    print("  2. Heron executed it, caught 15 → 'Fizz', filed a BLOCKING finding")
    print("  3. Kestrel fixed it and asked for counter-review")
    print("  4. Heron re-executed, approved, and only then approved GOAL-COMPLETE")
    print("\nThat review catch is the whole point: peers verify, nobody grades")
    print("their own homework. Next: `communicate init` to run YOUR crew.")


def cmd_demo_agent(args: argparse.Namespace) -> None:
    demo_agent_turn(args.name, Path.cwd())


# ── main ─────────────────────────────────────────────────────────────────────

def main() -> None:
    parser = argparse.ArgumentParser(prog="communicate", description=__doc__)
    sub = parser.add_subparsers(dest="cmd", required=True)

    p_demo = sub.add_parser("demo", help="watch two built-in agents collaborate (no API keys)")
    p_demo.set_defaults(fn=cmd_demo)

    p_init = sub.add_parser("init", help="guided setup: goal + agents -> crew.toml")
    p_init.add_argument("--force", action="store_true", help="overwrite existing crew.toml")
    p_init.add_argument("--defaults", action="store_true", help="skip the wizard, write the template")
    p_init.set_defaults(fn=cmd_init)

    p_run = sub.add_parser("run", help="run agents toward the goal")
    p_run.add_argument("--rounds", type=int, default=None)
    p_run.set_defaults(fn=cmd_run)

    p_status = sub.add_parser("status", help="show goal, agents, ledger tail")
    p_status.set_defaults(fn=cmd_status)

    p_watch = sub.add_parser("watch", help="live view of ledger entries as they land")
    p_watch.set_defaults(fn=cmd_watch)

    p_say = sub.add_parser("say", help="add an Owner note — the crew's top-priority instruction")
    p_say.add_argument("message", nargs="+", help="what to tell the crew")
    p_say.add_argument("--title", default="Guidance", help='entry title (default "Guidance")')
    p_say.add_argument("--to", default=None, metavar="AGENT",
                       help="address one specific agent instead of the whole crew")
    p_say.set_defaults(fn=cmd_say)

    p_rule = sub.add_parser("rule", help="standing behavioral rule for ONE agent, binding every turn")
    p_rule.add_argument("agent", help="which agent the rule binds")
    p_rule.add_argument("text", nargs="+", help="the rule")
    p_rule.set_defaults(fn=cmd_rule)

    p_stop = sub.add_parser("stop", help="halt a running crew after the current turn")
    p_stop.add_argument("reason", nargs="*", help="optional reason, recorded in the ledger")
    p_stop.set_defaults(fn=cmd_stop)

    p_inbox = sub.add_parser("inbox", help="what an agent must respond to (mentions, verdicts, Owner notes)")
    p_inbox.add_argument("agent", help="agent name (or Owner)")
    p_inbox.set_defaults(fn=cmd_inbox)

    p_claim = sub.add_parser("claim", help="claim an agent identity in the ledger (free-running agents)")
    p_claim.add_argument("name", help="unique agent name to claim")
    p_claim.add_argument("--role", default="Collaborator", help='e.g. "Implementer", "Reviewer"')
    p_claim.add_argument("--brief", default="", help="one-line working contract for this agent")
    p_claim.set_defaults(fn=cmd_claim)

    p_da = sub.add_parser("_demo-agent")  # internal: a scripted demo agent turn
    p_da.add_argument("name")
    p_da.add_argument("prompt", nargs="?")
    p_da.set_defaults(fn=cmd_demo_agent)

    args = parser.parse_args()
    args.fn(args)


if __name__ == "__main__":
    main()
