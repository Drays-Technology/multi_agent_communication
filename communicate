# ── demo ─────────────────────────────────────────────────────────────────────
# Two built-in agents collaborate on a tiny real task (fizzbuzz) using the
# REAL run loop. No API keys. The implementer ships a genuinely buggy first
# version; the reviewer actually executes the code, catches it, and issues a
# BLOCKING finding — so the demo shows the protocol's whole point.

BUGGY_FIZZBUZZ = '''\
def fizzbuzz(n: int) -> str:
    if n % 3 == 0:
        return "Fizz"
    if n % 5 == 0:
        return "Buzz"
    if n % 15 == 0:
        return "FizzBuzz"
    return str(n)


if __name__ == "__main__":
    for i in range(1, 21):
        print(fizzbuzz(i))
'''

FIXED_FIZZBUZZ = '''\
def fizzbuzz(n: int) -> str:
    if n % 15 == 0:
        return "FizzBuzz"
    if n % 3 == 0:
        return "Fizz"
    if n % 5 == 0:
        return "Buzz"
    return str(n)


if __name__ == "__main__":
    for i in range(1, 21):
        print(fizzbuzz(i))
'''


def run_fizzbuzz(root: Path) -> tuple[str, str]:
    """Execute the demo's fizzbuzz.py; return (line15, full output)."""
    result = subprocess.run(
        [sys.executable, "fizzbuzz.py"], cwd=root,
        capture_output=True, text=True, timeout=10,
    )
    lines = result.stdout.splitlines()
    return (lines[14] if len(lines) >= 15 else "", result.stdout)


def demo_agent_turn(name: str, root: Path) -> None:
    """Scripted-but-real agent: acts on the ACTUAL ledger + files each turn."""
    ledger = root / "communicate.md"
    text = ledger.read_text()
    src = root / "fizzbuzz.py"

    if name == "Kestrel":
        if "## Kestrel — PROPOSED" not in text:
            src.write_text(BUGGY_FIZZBUZZ)
            append_entry(ledger, "Kestrel", "PROPOSED: fizzbuzz.py first cut",
                "Wrote `fizzbuzz.py` (classic rules, printed for 1-20).\n"
                "Ran it — output looks right at a glance.\n\n"
                "**Review ask:** behavior check before we call the goal met.")
        elif "## Heron — BLOCKING" in text and "## Kestrel — COUNTER-REVIEW" not in text:
            src.write_text(FIXED_FIZZBUZZ)
            line15, _ = run_fizzbuzz(root)
            append_entry(ledger, "Kestrel", "COUNTER-REVIEW: divisibility order fixed",
                "You were right — the `% 15` check was unreachable below the\n"
                "`% 3` branch. Reordered most-specific-first and re-ran:\n"
                f"line 15 now prints `{line15}`. Review me back.")
        elif "## Heron — APPROVED: fix verified" in text and "GOAL-COMPLETE" not in text:
            _, output = run_fizzbuzz(root)
            append_entry(ledger, "Kestrel", "GOAL-COMPLETE: fizzbuzz verified",
                "Full run 1-20 checked against the rules line by line —\n"
                "all correct. Claiming the goal; needs your independent\n"
                "approval to close.")

    if name == "Heron":
        if "## Kestrel — PROPOSED" in text and "## Heron — BLOCKING" not in text:
            line15, _ = run_fizzbuzz(root)
            if line15 != "FizzBuzz":
                append_entry(ledger, "Heron", "BLOCKING: 15 prints the wrong thing",
                    "Reviewed by EXECUTION, not by reading the summary.\n\n"
                    "**Defect:** the `% 15` branch sits below `% 3`, so it can\n"
                    "never be reached.\n"
                    f"**Failure scenario:** input 15 → prints `{line15}`, "
                    "spec says `FizzBuzz`.\n"
                    "**Fix shape I'd approve:** most-specific divisor first.")
        elif "## Kestrel — COUNTER-REVIEW" in text and "## Heron — APPROVED: fix verified" not in text:
            line15, _ = run_fizzbuzz(root)
            verdict = ("APPROVED: fix verified" if line15 == "FizzBuzz"
                       else "BLOCKING: still wrong")
            append_entry(ledger, "Heron", verdict,
                f"Re-executed `fizzbuzz.py`: line 15 → `{line15}`. "
                "Checked the diff too — order is most-specific-first. No findings.")
        elif "## Kestrel — GOAL-COMPLETE" in text and "## Heron — APPROVED: GOAL-COMPLETE" not in text:
            line15, _ = run_fizzbuzz(root)
            if line15 == "FizzBuzz":
                append_entry(ledger, "Heron", "APPROVED: GOAL-COMPLETE",
                    "Independent final verification: executed the program, "
                    "checked all 20 lines against the rules. Goal met.")


def cmd_demo(_: argparse.Namespace) -> None:
    import os

    root = Path.cwd() / "communicate-demo"
    if root.exists():
        shutil.rmtree(root)
    root.mkdir()

    goal = ("Write fizzbuzz.py (print 1-20 with the classic rules) and get it "
            "verified by execution, not by trust.")
    (root / "communicate.md").write_text(
        LEDGER_TEMPLATE.format(date=today(), goal=goal)
    )
    me = shlex.quote(str(Path(__file__).resolve()))
    py = shlex.quote(sys.executable)
    (root / CONFIG).write_text(CONFIG_TEMPLATE.format(
        goal=goal, max_rounds=4,
        a1_name="Kestrel", a1_command=f"{py} {me} _demo-agent Kestrel {{prompt}}",
        a2_name="Heron", a2_command=f"{py} {me} _demo-agent Heron {{prompt}}",
    ))

    print("communicate demo — two built-in agents, one goal, zero API keys.")
    print("Kestrel implements; Heron reviews BY EXECUTING the code.")
    print(f"Everything happens in ./{root.name}/ — recreated each demo.\n")

    old = Path.cwd()
    os.chdir(root)
    try:
        cmd_run(argparse.Namespace(rounds=None))
    finally:
        os.chdir(old)

    print(f"\nWhat just happened (full story: {root / 'communicate.md'}):")
    print("  1. Kestrel shipped fizzbuzz.py with a REAL bug (unreachable %15 branch)")
    print("  2. Heron executed it, caught 15 → 'Fizz', filed a BLOCKING finding")
    print("  3. Kestrel fixed it and asked for counter-review")
    print("  4. Heron re-executed, approved, and only then approved GOAL-COMPLETE")
    print("\nThat review catch is the whole point: peers verify, nobody grades")
    print("their own homework. Next: `communicate init` to run YOUR crew.")


