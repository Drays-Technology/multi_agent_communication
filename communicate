def cmd_doctor(args: argparse.Namespace) -> None:
    """Preflight the crew: is every agent actually invocable before we burn
    a real run on finding out it isn't?"""
    problems = 0

    def check(ok: bool, label: str, detail: str = "") -> None:
        nonlocal problems
        mark = paint("✓", "32") if ok else paint("✗", "1;31")
        print(f"  {mark} {label}" + (paint(f" — {detail}", "2") if detail else ""))
        if not ok:
            problems += 1

    print("communicate doctor\n")
    check(sys.version_info >= (3, 11), f"python {sys.version.split()[0]} (need 3.11+)")

    root = Path.cwd()
    if find_config(root) is None:
        check(False, f"{CONFIG_DIR}/{CONFIG}", "not found — run `communicate init` first")
        sys.exit(1)
    cfg = load_config(root)  # exits with a precise message on structural errors
    check(True, f"{CONFIG} parsed — {len(cfg['agents'])} agents, "
                f"compact_every={cfg['compact_every']}, archive_after={cfg['archive_after']}")
    ledger = root / cfg["ledger"]
    check(ledger.exists(), f"ledger {cfg['ledger']}",
          "" if ledger.exists() else "missing — `communicate init` creates it")

    for agent in cfg["agents"]:
        name = agent["name"]
        try:
            argv = shlex.split(agent["command"])
        except ValueError as exc:
            check(False, f"{name}: command parses", str(exc))
            continue
        check("{prompt}" in argv, f"{name}: command has a {{prompt}} placeholder")
        exe_path = shutil.which(argv[0]) if argv else None
        check(exe_path is not None, f"{name}: executable {argv[0]!r}",
              exe_path or "not found on PATH — is the CLI installed?")
        if args.live and exe_path and "{prompt}" in argv:
            test_prompt = ("This is a connectivity test from `communicate doctor`. "
                           "Do nothing else; reply with exactly: CREW-OK")
            live_argv = [test_prompt if t == "{prompt}" else t for t in argv]
            print(f"  … {name}: live round-trip (may take a minute, costs a few tokens)")
            try:
                res = subprocess.run(live_argv, capture_output=True, text=True,
                                     timeout=args.timeout)
                ok = "CREW-OK" in (res.stdout + res.stderr)
                check(ok, f"{name}: live round-trip",
                      "responded correctly" if ok else
                      f"no CREW-OK in output (exit {res.returncode}) — check auth/flags; "
                      f"first output line: {(res.stdout + res.stderr).strip().splitlines()[0][:80] if (res.stdout + res.stderr).strip() else '(empty)'}")
            except subprocess.TimeoutExpired:
                check(False, f"{name}: live round-trip", f"timed out after {args.timeout}s")

    if problems:
        print(f"\n{problems} problem{'s' if problems != 1 else ''} — fix before `communicate run`.")
        sys.exit(1)
    print("\nall checks passed — ready to run."
          + ("" if args.live else " (add --live to test real agent round-trips)"))


def cmd_commands(_: argparse.Namespace | None = None) -> None:
    """The one-screen cheat sheet."""
    def sect(title):
        print(paint("▌ " + title, "1;36"))

    def row(cmd, desc):
        pad = " " * max(1, 34 - len(cmd))
        base, _, rest = cmd.partition(" ")
        parts = rest.split(" ", 1)
        sub = parts[0] if parts else ""
        args = (" " + parts[1]) if len(parts) > 1 else ""
        print("  " + paint(base + " ", "2") + paint(sub, "1;92")
              + paint(args, "33") + pad + paint(desc, "2"))

    sect("getting started")
    row("communicate demo", "watch two built-in agents collaborate (free, ~1s)")
    row("communicate init", "guided setup: goal, CLI + model per agent, names")
    row("communicate doctor [--live]", "preflight: CLIs installed, auth works")
    row("communicate add-agent [...]", "grow the crew (auto-names Agent3, Agent4, …)")
    sect("running")
    row("communicate run [--rounds N]", "agents take turns until GOAL-COMPLETE is approved")
    row('communicate goal ["<new goal>"]', "show the goal, or set a new one (memory kept)")
    row("communicate status", "goal, roster, ledger tail, done-or-not")
    row("communicate watch", "live entries + your comment line (see below)")
    sect("steering (also available inside watch)")
    row("communicate say <msg>", "guidance for everyone — top-priority instruction")
    row("communicate say --to A <msg>", "one-time directive into agent A's inbox")
    row("communicate rule A <text>", "standing rule for A — re-asserted EVERY turn")
    row("communicate stop [reason]", "halt after the current turn; re-run resumes")
    row("communicate inbox <agent>", "what that agent owes: mentions, verdicts, notes")
    row('communicate ask "<question>"', "one-shot answer from an agent, no other work")
    sect("memory (mostly automatic)")
    row("communicate compact", "fold old history into the digest agents boot from")
    row("communicate archive", "relocate pre-digest entries to queryable JSONL")
    row("communicate history <text>", "search everything ever written, live + archived")
    sect("free-running agents (no runner)")
    row("communicate claim <name>", "claim an identity in the ledger, collision-checked")
    print(paint("\ninside `communicate watch`: ", "1")
          + paint("text = guidance · @Agent msg = directive · "
                  "/rule A text · /stop · /quit", "2"))
    print(paint("bare `communicate` opens an interactive session — same "
                "commands, no prefix.", "2"))


