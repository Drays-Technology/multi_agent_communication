# ── helpers ──────────────────────────────────────────────────────────────────

def die(msg: str) -> None:
    print(f"communicate: {msg}", file=sys.stderr)
    sys.exit(1)


def today() -> str:
    return datetime.date.today().isoformat()


USE_COLOR = sys.stdout.isatty() or bool(os.environ.get("FORCE_COLOR"))


def paint(text: str, code: str) -> str:
    """ANSI-wrap when on a terminal. Codes: 1 bold, 2 dim, 31 red, 32 green,
    33 yellow, 35 magenta, 36 cyan, 92 bright green."""
    return f"\033[{code}m{text}\033[0m" if USE_COLOR else text


def load_config(root: Path) -> dict:
    path = find_config(root)
    if path is None:
        die(f"no crew here ({CONFIG_DIR}/{CONFIG} not found) — run "
            f"`communicate init` first (or `communicate demo` to see how this works)")
    with path.open("rb") as fh:
        cfg = tomllib.load(fh)
    for key in ("goal", "agents"):
        if key not in cfg:
            die(f"{CONFIG} missing required key: {key}")
    if len(cfg["agents"]) < 2:
        die("at least two agents are required — peer review needs a peer")
    names = [a["name"] for a in cfg["agents"]]
    if len(names) != len(set(names)):
        die(f"agent names must be unique, got: {names}")
    if "Owner" in names:
        die('"Owner" is reserved for the human — rename that agent')
    cfg.setdefault("ledger", "communicate.md")
    cfg.setdefault("max_rounds", 12)
    cfg.setdefault("timeout_minutes", 30)
    cfg.setdefault("digest", f"{CONFIG_DIR}/digest.md")
    cfg.setdefault("compact_every", 25)   # entries between compactions; 0 = off
    cfg.setdefault("archive_after", 120)  # live-ledger entries that trigger archival; 0 = off
    cfg.setdefault("archive", f"{CONFIG_DIR}/archive.jsonl")
    return cfg


HEADING_RE = re.compile(r"^## (\S+) — (.*?)(?: \((\d{4}-\d{2}-\d{2})\))?$")


def archive_ledger(cfg: dict, root: Path) -> tuple[int, Path] | None:
    """Losslessly relocate old entries to a structured JSONL archive.

    Moves every entry BEFORE the last COMPACTED marker — except Owner
    standing rules, which stay live because they bind every future turn —
    into one-JSON-per-entry lines that grep, jq, and `communicate history`
    can query. The live ledger keeps: its header, a pointer entry, the
    standing rules, the COMPACTED marker, and everything after it. Nothing
    is summarized or dropped: the archive holds the full text, and git
    history holds the original file anyway.
    """
    import json

    ledger = root / cfg["ledger"]
    text = ledger.read_text()
    prefix_end = text.find("## ")
    if prefix_end == -1:
        return None
    prefix = text[:prefix_end]
    entries = split_entries_by_author(text)

    last_compacted = -1
    for i, (_, entry) in enumerate(entries):
        if "— COMPACTED:" in entry.splitlines()[0]:
            last_compacted = i
    if last_compacted <= 0:
        return None  # nothing safely archivable without a digest covering it

    to_archive, to_keep = [], []
    for i, (author, entry) in enumerate(entries):
        heading = entry.splitlines()[0]
        keep = (
            i >= last_compacted
            or (author == "Owner" and "— Standing rule for @" in heading)
        )
        (to_keep if keep else to_archive).append((author, entry))
    if not to_archive:
        return None

    archive_path = root / cfg["archive"]
    archive_path.parent.mkdir(parents=True, exist_ok=True)
    existing = sum(1 for _ in archive_path.open()) if archive_path.exists() else 0
    with archive_path.open("a") as fh:
        for seq, (author, entry) in enumerate(to_archive, existing + 1):
            lines = entry.splitlines()
            m = HEADING_RE.match(lines[0])
            fh.write(json.dumps({
                "n": seq,
                "author": author,
                "title": m.group(2) if m else lines[0][3:],
                "date": (m.group(3) if m else None),
                "body": "\n".join(lines[1:]).strip(),
            }, ensure_ascii=False) + "\n")

    pointer = (
        f"## Ledger — ARCHIVED: {len(to_archive)} entries moved to "
        f"{cfg['archive']} ({today()})\n\n"
        f"Lossless relocation (full text preserved, one JSON per entry). "
        f"Search old history with `communicate history <text>` or grep."
    )
    ledger.write_text(
        prefix + pointer + "\n\n" + "\n\n".join(e for _, e in to_keep) + "\n"
    )
    return len(to_archive), archive_path


def entries_since_compaction(ledger_text: str) -> int:
    """Entries after the most recent COMPACTED marker (all of them if none)."""
    entries = entry_headings(ledger_text)
    last = -1
    for i, heading in enumerate(entries):
        if "— COMPACTED:" in heading:
            last = i
    return len(entries) - last - 1


def entry_headings(ledger_text: str) -> list[str]:
    return re.findall(r"^## .*$", ledger_text, re.MULTILINE)


GOAL_MARKER_RE = re.compile(r"^## Owner — (?:New goal set|Goal set)", re.MULTILINE)


def active_goal_region(ledger_text: str) -> str:
    """The ledger from the most recent Owner goal entry onward — completion
    of a PREVIOUS goal must not satisfy the current one."""
    matches = list(GOAL_MARKER_RE.finditer(ledger_text))
    return ledger_text[matches[-1].start():] if matches else ledger_text


def goal_complete(ledger_text: str, agent_names: list[str]) -> bool:
    """Done = one agent claimed GOAL-COMPLETE and a DIFFERENT agent approved,
    both since the CURRENT goal was set."""
    ledger_text = active_goal_region(ledger_text)
    claimers = set(
        re.findall(r"^## (\S+) — GOAL-COMPLETE", ledger_text, re.MULTILINE)
    )
    approvers = set(
        re.findall(r"^## (\S+) — APPROVED: GOAL-COMPLETE", ledger_text, re.MULTILINE)
    )
    claimers &= set(agent_names)
    approvers &= set(agent_names)
    return bool(claimers) and bool(approvers - claimers)


def append_entry(ledger: Path, agent: str, title: str, body: str) -> None:
    with ledger.open("a") as fh:
        fh.write(f"\n## {agent} — {title} ({today()})\n\n{body.rstrip()}\n")


def owner_stop_count(ledger_text: str) -> int:
    return len(re.findall(r"^## Owner — STOP", ledger_text, re.MULTILINE))


def split_entries_by_author(ledger_text: str) -> list[tuple[str, str]]:
    """[(author, whole_entry), ...] in ledger order."""
    out = []
    for entry in re.split(r"(?m)^(?=## )", ledger_text):
        m = re.match(r"^## (\S+) — ", entry)
        if m:
            out.append((m.group(1), entry.rstrip()))
    return out


def standing_rules(ledger_text: str, agent_name: str) -> list[str]:
    """All Owner 'Standing rule for @X' bodies for this agent, in order.

    Rules bind until the Owner posts a newer rule changing them — so they
    are injected into EVERY turn prompt, unlike inbox items, which drop out
    of the digest once the agent has taken a turn.
    """
    rules = []
    pattern = re.compile(rf"— Standing rule for @{re.escape(agent_name)}\b")
    for author, entry in split_entries_by_author(ledger_text):
        if author != "Owner":
            continue
        lines = entry.splitlines()
        if pattern.search(lines[0]):
            body = "\n".join(lines[1:]).strip()
            if body:
                rules.append(body)
    return rules


def compute_inbox(ledger_text: str, agent_name: str) -> list[str]:
    """What this agent must see before working: every entry since its own
    last entry, tagged when it demands something of the agent.

    Tags: [MENTIONS YOU]      — contains @agent_name
          [NEEDS YOUR REVIEW] — PROPOSED / COUNTER-REVIEW by someone else
          [BLOCKING]          — a blocking finding (fix or rebut)
          [OWNER]             — the human spoke; top priority
    """
    entries = split_entries_by_author(ledger_text)
    last_own = -1
    for i, (author, _) in enumerate(entries):
        if author == agent_name:
            last_own = i
    digest = []
    mention = f"@{agent_name}"
    for author, entry in entries[last_own + 1:]:
        if author == agent_name:
            continue
        heading = entry.splitlines()[0]
        tags = []
        if author == "Owner":
            tags.append("[OWNER]")
        if mention in entry:
            tags.append("[MENTIONS YOU]")
        if re.search(r"— (PROPOSED|COUNTER-REVIEW)", heading):
            tags.append("[NEEDS YOUR REVIEW]")
        if "— BLOCKING" in heading:
            tags.append("[BLOCKING]")
        digest.append(f"{' '.join(tags) + ' ' if tags else ''}{heading}")
    return digest


# ── init (wizard) ────────────────────────────────────────────────────────────

def detect_agent_clis() -> list[tuple[str, str]]:
    return [(name, cmd) for name, cmd in KNOWN_AGENT_CLIS if shutil.which(name)]


def ask(prompt: str, default: str = "") -> str:
    suffix = f" [{default}]" if default else ""
    answer = input(f"{prompt}{suffix}: ").strip()
    return answer or default


def cmd_init(args: argparse.Namespace) -> None:
    root = Path.cwd()
    if find_config(root) is not None and not args.force:
        die(f"a crew already exists here (use --force to overwrite)")
    cfg_path = root / CONFIG_DIR / CONFIG
    cfg_path.parent.mkdir(exist_ok=True)

    goal = DEFAULT_GOAL
    a1_name, a2_name = "Agent1", "Agent2"
    fallback = "your-agent-cli {prompt}"
    a1_command = a2_command = fallback

    interactive = sys.stdin.isatty() and not args.defaults
    if interactive:
        print("communicate init — set up a crew in 3 questions. "
              "(Enter accepts the [default].)\n")

        print("1) What is the goal? Be specific about what 'done' looks like.")
        print("   Type it below; finish with an empty line.")
        lines: list[str] = []
        while True:
            line = input("   > ")
            if not line.strip() and lines:
                break
            if line.strip():
                lines.append(line)
        goal = "\n".join(lines)

        detected = detect_agent_clis()
        print("\n2) Which agent CLI powers each agent? Mixing vendors is a")
        print("   feature — a reviewer on a different model catches more.")
        if detected:
            for i, (name, cmd) in enumerate(detected, 1):
                print(f"   {i}. {name}  ({cmd})")
            print(f"   {len(detected) + 1}. other (edit crew.toml afterward)")

            def pick(label: str) -> str:
                choice = ask(f"   {label} uses", "1")
                try:
                    cli_name, cmd = detected[int(choice) - 1]
                except (ValueError, IndexError):
                    return fallback
                hint = MODEL_HINTS.get(cli_name, "Enter = CLI default")
                model = ask(f"   {label} model ({hint})", "")
                if model:
                    cmd += f" {MODEL_FLAGS.get(cli_name, '--model')} {model}"
                return cmd

            a1_command = pick("implementer")
            a2_command = pick("reviewer")
        else:
            print("   No known agent CLI found on PATH (looked for: "
                  + ", ".join(n for n, _ in KNOWN_AGENT_CLIS) + ").")
            print(f"   Writing a placeholder — edit `command` in {CONFIG} before running.")

        print("\n3) Name the agents (they sign the ledger with these; no")
        print("   spaces — @mentions and ledger parsing need single tokens).")
        a1_name = ask("   implementer name", a1_name).replace(" ", "")
        a2_name = ask("   reviewer name", a2_name).replace(" ", "")
        if a2_name == a1_name:
            a2_name = a1_name + "-2"
            print(f"   names must differ — reviewer renamed to {a2_name}")

    cfg_path.write_text(CONFIG_TEMPLATE.format(
        goal=goal, max_rounds=12,
        a1_name=a1_name, a1_command=a1_command,
        a2_name=a2_name, a2_command=a2_command,
    ))
    ledger = root / "communicate.md"
    if not ledger.exists():
        ledger.write_text(LEDGER_TEMPLATE.format(date=today(), goal=goal))

    print(f"\nwrote {CONFIG_DIR}/{CONFIG} and communicate.md — the ledger is "
          f"the only file kept in your project root; config, digest, archive "
          f"and logs all live under {CONFIG_DIR}/")
    if interactive and (a1_command != fallback):
        print("next: `communicate run`  (each turn invokes your agent CLI — "
              "normal API charges apply)")
    else:
        print(f"next: edit {CONFIG} (goal + agent commands), then `communicate run`")


# ── run ──────────────────────────────────────────────────────────────────────

def run_turn(agent: dict, cfg: dict, round_no: int, log_dir: Path, ledger: Path) -> None:
    ledger_text = ledger.read_text() if ledger.exists() else ""
    inbox = compute_inbox(ledger_text, agent["name"])
    inbox_text = "\n".join(f"- {line}" for line in inbox) if inbox else \
        "- (nothing new since your last turn)"
    rules = standing_rules(ledger_text, agent["name"])
    rules_text = "\n".join(f"- {r}" for r in rules) if rules else "- (none)"
    digest_path = Path.cwd() / cfg["digest"]
    memory_hint = (MEMORY_HINT_DIGEST.format(digest=cfg["digest"])
                   if digest_path.exists() else MEMORY_HINT_FRESH)
    prompt = TURN_PROMPT.format(
        name=agent["name"],
        role=agent.get("role", "Collaborator"),
        brief=agent.get("brief", ""),
        goal=cfg["goal"].strip(),
        ledger=cfg["ledger"],
        memory_hint=memory_hint,
        inbox=inbox_text,
        standing_rules=rules_text,
        date=today(),
        round=round_no,
        max_rounds=cfg["max_rounds"],
    )
    argv = [
        prompt if token == "{prompt}" else token
        for token in shlex.split(agent["command"])
    ]
    if prompt not in argv:
        die(f"agent {agent['name']}: command must contain {{prompt}}")
    log_path = log_dir / f"round{round_no:02d}-{agent['name']}.log"
    before = entry_headings(ledger.read_text()) if ledger.exists() else []
    stream = cfg.get("stream", True)
    print("  " + paint("▸", "36") + " " + paint(agent["name"], "1")
          + paint(f" ({agent.get('role', '?')}) working …", "2")
          + ("" if stream else f" (watch: tail -f {log_path})"), flush=True)
    started = time.monotonic()
    try:
        with log_path.open("w") as log:
            proc = subprocess.Popen(argv, stdout=subprocess.PIPE,
                                    stderr=subprocess.STDOUT, text=True)

            def _tee() -> None:
                assert proc.stdout is not None
                for raw in proc.stdout:
                    log.write(raw)
                    log.flush()
                    line = raw.rstrip()
                    if stream and line:
                        print(paint(f"    │ {line[:160]}", "2"), flush=True)

            reader = threading.Thread(target=_tee, daemon=True)
            reader.start()
            try:
                proc.wait(timeout=cfg["timeout_minutes"] * 60)
            except subprocess.TimeoutExpired:
                proc.kill()
                raise
            reader.join(timeout=5)
        elapsed = time.monotonic() - started
        after = entry_headings(ledger.read_text()) if ledger.exists() else []
        new = after[len(before):]
        if new:
            for heading in new:
                print(f"    ↳ {colorize_heading(heading, USE_COLOR)}")
        else:
            print(paint(f"    ↳ (no ledger entry written — see {log_path})", "33"))
        print(paint(f"    {elapsed:.0f}s", "2"))
    except subprocess.TimeoutExpired:
        print(f"    ↳ TIMEOUT after {cfg['timeout_minutes']}m (log: {log_path})")
    except FileNotFoundError:
        die(f"agent {agent['name']}: command not found: {argv[0]}")


def run_compaction(cfg: dict, log_dir: Path, ledger: Path) -> None:
    """One compaction turn by the crew's first agent: fold ledger history
    into the digest file so every later boot reads O(digest) tokens, not
    O(ledger)."""
    agent = cfg["agents"][0]
    prompt = COMPACT_PROMPT.format(
        name=agent["name"], ledger=cfg["ledger"], digest=cfg["digest"],
        date=today(),
    )
    argv = [
        prompt if token == "{prompt}" else token
        for token in shlex.split(agent["command"])
    ]
    log_path = log_dir / f"compact-{today()}.log"
    print(f"  ◆ {agent['name']} compacting memory → {cfg['digest']} …", flush=True)
    try:
        with log_path.open("w") as log:
            subprocess.run(argv, stdout=log, stderr=subprocess.STDOUT,
                           timeout=cfg["timeout_minutes"] * 60, check=False)
        since = entries_since_compaction(ledger.read_text())
        if since == 0:
            print(f"    ↳ compacted (log: {log_path})")
        else:
            print(f"    ↳ compaction did not write its COMPACTED marker — "
                  f"see {log_path}; continuing uncompacted")
    except subprocess.TimeoutExpired:
        print(f"    ↳ compaction TIMEOUT — continuing uncompacted (log: {log_path})")


def cmd_run(args: argparse.Namespace) -> None:
    root = Path.cwd()
    cfg = load_config(root)
    if args.rounds:
        cfg["max_rounds"] = args.rounds
    ledger = root / cfg["ledger"]
    if not ledger.exists():
        die(f"ledger {cfg['ledger']} not found — run `communicate init`")
    log_dir = root / ".communicate" / "logs"
    log_dir.mkdir(parents=True, exist_ok=True)
    names = [a["name"] for a in cfg["agents"]]

    roster = ", ".join(
        "{}({})".format(a["name"], a.get("role", "?")) for a in cfg["agents"]
    )
    print(f"goal: {cfg['goal'].strip().splitlines()[0]} …")
    print(f"agents: {roster}")
    print("you: " + paint("communicate watch", "1;92") + paint(" to observe · ", "2")
          + paint("communicate say <msg>", "1;92") + paint(" to guide · ", "2")
          + paint("communicate stop", "1;92") + paint(" to halt", "2") + "\n")

    stops_at_launch = owner_stop_count(ledger.read_text())
    for round_no in range(1, cfg["max_rounds"] + 1):
        if cfg["compact_every"] and \
                entries_since_compaction(ledger.read_text()) >= cfg["compact_every"]:
            run_compaction(cfg, log_dir, ledger)
        if cfg["archive_after"] and \
                len(entry_headings(ledger.read_text())) >= cfg["archive_after"]:
            result = archive_ledger(cfg, root)
            if result:
                moved, path = result
                print(f"  ▣ archived {moved} old entries → {path} "
                      f"(lossless; `communicate history <text>` searches them)")
        print(paint(f"round {round_no}/{cfg['max_rounds']}", "1;36"))
        for agent in cfg["agents"]:
            run_turn(agent, cfg, round_no, log_dir, ledger)
            text = ledger.read_text()
            if goal_complete(text, names):
                print(paint("\n✓ GOAL-COMPLETE claimed and independently APPROVED — stopping.", "1;92"))
                print(f"  read the full story: {ledger}")
                return
            if owner_stop_count(text) > stops_at_launch:
                print(paint("\n■ Owner said STOP — halting after this turn.", "1;31"))
                print(f"  the ledger holds the state: {ledger} — re-run to continue.")
                return
    print(f"\nmax rounds ({cfg['max_rounds']}) reached without an approved "
          f"GOAL-COMPLETE. The ledger holds the state — re-run to continue.")


