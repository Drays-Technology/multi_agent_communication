def cmd_history(args: argparse.Namespace) -> None:
    import json

    root = Path.cwd()
    cfg = load_config(root)
    query = " ".join(args.query).lower()
    hits = 0
    archive_path = root / cfg["archive"]
    if archive_path.exists():
        for line in archive_path.open():
            row = json.loads(line)
            text = f"{row['author']} {row['title']} {row['body']}".lower()
            if query in text:
                hits += 1
                print(f"[archive #{row['n']}] ## {row['author']} — "
                      f"{row['title']}{' (' + row['date'] + ')' if row['date'] else ''}")
                for body_line in row["body"].splitlines():
                    if query in body_line.lower():
                        print(f"    {body_line.strip()}")
    ledger = root / cfg["ledger"]
    if ledger.exists():
        for author, entry in split_entries_by_author(ledger.read_text()):
            if query in entry.lower():
                hits += 1
                print(f"[live] {entry.splitlines()[0]}")
    print(f"{hits} match{'es' if hits != 1 else ''} for {query!r}"
          + ("" if hits else " — try a shorter term"))


