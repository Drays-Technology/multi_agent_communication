# ── owner interface: watch / say / stop ─────────────────────────────────────
# The human is the crew's conscience. These commands need no running process
# to coordinate with — they read and append the same ledger the agents use,
# which is the whole point of the protocol.

VERDICT_COLORS = [
    ("BLOCKING", "\033[31m"),        # red
    ("APPROVED: GOAL-COMPLETE", "\033[92m"),
    ("GOAL-COMPLETE", "\033[92m"),   # bright green
    ("APPROVED", "\033[32m"),        # green
    ("COUNTER-REVIEW", "\033[35m"),  # magenta
    ("PROPOSED", "\033[33m"),        # yellow
    ("STOP", "\033[31m"),
]
RESET = "\033[0m"
BOLD = "\033[1m"
DIM = "\033[2m"


def colorize_heading(heading: str, use_color: bool) -> str:
    if not use_color:
        return heading
    for keyword, color in VERDICT_COLORS:
        if f"— {keyword}" in heading or f"— {keyword}:" in heading:
            return f"{color}{BOLD}{heading}{RESET}"
    if heading.startswith("## Owner"):
        return f"\033[36m{BOLD}{heading}{RESET}"  # cyan: the human's voice
    return f"{BOLD}{heading}{RESET}"


def split_entries(ledger_text: str) -> list[str]:
    """The ledger as a list of whole entries (heading + body)."""
    parts = re.split(r"(?m)^(?=## )", ledger_text)
    return [p.rstrip() for p in parts if p.startswith("## ")]


def cmd_watch(_: argparse.Namespace) -> None:
    """The owner's window: entries stream in as agents write them, and the
    input line at the bottom posts straight into the ledger — comment,
    direct, rule, or stop without leaving the view."""
    root = Path.cwd()
    cfg = load_config(root)
    ledger = root / cfg["ledger"]
    if not ledger.exists():
        die(f"ledger {cfg['ledger']} not found")
    names = _crew_names(cfg)

    print(paint(f"watching {cfg['ledger']}", "1;36")
          + paint("  — your keyboard is live:", "2"))
    print(paint("  type a note = guidance for everyone  ·  @Agent msg = directive"
                "\n  /rule Agent text  ·  /ask question  ·  /status  ·  /stop  ·  /help  ·  /quit\n", "2"))

    entries = split_entries(ledger.read_text())
    for entry in entries[-3:]:
        heading, _, body = entry.partition("\n")
        print(colorize_heading(heading, USE_COLOR))
        print(body.strip() + "\n" if body.strip() else "")

    if goal_complete(ledger.read_text(), names):
        print(paint("⚠ this crew's goal is COMPLETE — no agents are working, so no new", "33"))
        print(paint("  entries will appear. ", "33") + paint("communicate ask \"…\"", "1;92")
              + paint(" answers questions; a new", "33"))
        print(paint("  goal in crew.toml + ", "33") + paint("communicate run", "1;92")
              + paint(" starts new work. Your input line", "33"))
        print(paint("  below still posts to the ledger.\n", "33"))
    else:
        print(paint(f"({len(entries)} entries so far — new ones appear here the moment an", "2"))
        print(paint(" agent writes. If nothing is running, start `communicate run` in", "2"))
        print(paint(" another terminal.)\n", "2"))

    seen = [len(entries)]
    stop_flag = threading.Event()

    def _follow() -> None:
        while not stop_flag.is_set():
            time.sleep(1.0)
            try:
                current = split_entries(ledger.read_text())
            except OSError:
                continue
            if len(current) > seen[0]:
                print()   # step past any half-typed input line
                for entry in current[seen[0]:]:
                    heading, _, body = entry.partition("\n")
                    print(colorize_heading(heading, USE_COLOR))
                    print(body.strip() + "\n" if body.strip() else "")
                seen[0] = len(current)
                print(paint("you> ", "1;36"), end="", flush=True)

    follower = threading.Thread(target=_follow, daemon=True)
    follower.start()

    try:
        while True:
            try:
                line = input(paint("you> ", "1;36")).strip()
            except (EOFError, KeyboardInterrupt):
                break
            if not line:
                continue
            if line in ("/quit", "/q", "quit", "exit"):
                break
            if line in ("/status", "status"):
                cmd_status(argparse.Namespace())
                continue
            if line in ("/help", "/commands", "help", "?"):
                cmd_commands()
                continue
            if line in ("run", "/run"):
                print(paint("  run the crew from ANOTHER terminal: ", "33")
                      + paint("communicate run", "1;92")
                      + paint("  (this window stays open to watch and steer)", "33"))
                continue
            if line.startswith("/ask"):
                q = line[4:].strip()
                if not q:
                    print(paint("  usage: /ask is the website responsive?", "33"))
                    continue
                cmd_ask(argparse.Namespace(question=[q], agent=None))
                continue
            if line.startswith("/stop"):
                reason = line[5:].strip() or "Halt after the current turn."
                append_entry(ledger, "Owner", "STOP", reason)
                print(paint("  ■ STOP posted — a running crew halts after this turn.", "31"))
                continue
            if line.startswith("/rule "):
                parts = line[6:].split(None, 1)
                if len(parts) < 2 or parts[0] not in names:
                    print(paint(f"  usage: /rule <agent> <text> — crew: {', '.join(names)}", "33"))
                    continue
                append_entry(ledger, "Owner", f"Standing rule for @{parts[0]}", parts[1])
                print(paint(f"  standing rule recorded for {parts[0]} (binds every turn).", "32"))
                continue
            if line.startswith("@"):
                parts = line[1:].split(None, 1)
                if len(parts) < 2 or parts[0] not in names:
                    print(paint(f"  usage: @<agent> <message> — crew: {', '.join(names)}", "33"))
                    continue
                append_entry(ledger, "Owner", f"Directive for @{parts[0]}", parts[1])
                print(paint(f"  directive posted to {parts[0]}'s inbox.", "32"))
                continue
            append_entry(ledger, "Owner", "Guidance", line)
            print(paint("  noted — every agent treats your newest entry as top priority.", "32"))
            if goal_complete(ledger.read_text(), names):
                print(paint("  ⚠ but the goal is already COMPLETE — no run is active, so", "33"))
                print(paint("    nobody will read this. For a question, use ", "33")
                      + paint("communicate ask", "1;92")
                      + paint('; for new work, set a new goal and ', "33")
                      + paint("communicate run", "1;92") + paint(".", "33"))
    finally:
        stop_flag.set()
        print("\nleft the room — the crew keeps working. "
              "`communicate status` for a summary anytime.")


